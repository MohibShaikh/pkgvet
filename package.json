{
  "name": "pkgvet",
  "version": "0.1.5",
  "description": "Pre-flight inspector for npm packages: statically checks a package before you run or install it, and reports its risk level and what it can touch. Never executes the package.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MohibShaikh/pkgvet.git"
  },
  "homepage": "https://github.com/MohibShaikh/pkgvet#readme",
  "bugs": "https://github.com/MohibShaikh/pkgvet/issues",
  "bin": {
    "pkgvet": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "npm",
    "npx",
    "security",
    "supply-chain",
    "static-analysis",
    "cli",
    "agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "commander": "^12.0.0",
    "leven": "^4.0.0",
    "semver": "^7.8.5",
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/semver": "^7.7.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
